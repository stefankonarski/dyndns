<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}DynDNS Admin{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 120'%3E%3Ccircle cx='60' cy='60' r='56' fill='%230f172a'/%3E%3Cpath d='M24 64h72' stroke='%2338bdf8' stroke-width='8' stroke-linecap='round'/%3E%3Cpath d='M40 42c8-10 32-10 40 0' stroke='%23f97316' stroke-width='8' fill='none' stroke-linecap='round'/%3E%3C/svg%3E">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>
<body>
{% if app.user %}
    <header class="topbar">
        <a class="brand" href="{{ path('app_dashboard') }}" title="Zum Dashboard">
            <span class="brand-mark">DDNS</span>
            <span class="brand-text">DynDNS Control</span>
        </a>
        <nav class="topnav">
            <a href="{{ path('app_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_config') }}">Konfiguration</a>
            <a href="{{ path('app_logs') }}">Logs</a>
            <a href="{{ path('app_history') }}">Historie</a>
            <a href="{{ path('app_logout') }}">Logout</a>
        </nav>
    </header>
{% endif %}

<main class="page">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash-{{ type }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
    {% block body %}{% endblock %}
</main>
</body>
</html>
